# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# ──────────────────────────────────────────────
# Node / npm — everywhere in the repo
# ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log
yarn-debug.log*
package-lock.json
.npm/

# ──────────────────────────────────────────────
# Compiled output
# ──────────────────────────────────────────────
/dist
dist/
/tmp
/out-tsc
/bazel-out
*.js.map
*.d.ts.map

# ──────────────────────────────────────────────
# Angular specific
# ──────────────────────────────────────────────
/.angular/cache
.angular/
.sass-cache/
/coverage
/typings
*.ngc.json

# ──────────────────────────────────────────────
# Environment / secrets (NUNCA subir al repo)
# ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
*.log
logs/
/connect.lock
/libpeerconnection.log
testem.log

# ──────────────────────────────────────────────
# IDEs and editors
# ──────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# ──────────────────────────────────────────────
# System files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
__screenshots__/

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.tgz
*.zip
